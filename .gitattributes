# Enforce LF line endings for all text files
* text=auto eol=lf

# Ensure specific files use LF
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.go text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# ── Linguist overrides ──────────────────────────────────────────────────────
# Prevent non-code files from skewing GitHub language statistics

# Markup / documentation
*.html linguist-documentation
*.css linguist-documentation
*.scss linguist-documentation
*.tex linguist-documentation
*.ipynb linguist-documentation

# Config / infrastructure
Justfile linguist-vendored
justfile linguist-vendored
Makefile linguist-vendored
Dockerfile linguist-vendored
*.dockerfile linguist-vendored
*.nix linguist-vendored
*.sh linguist-vendored

# Generated output
*.svg linguist-generated
dist/ linguist-generated
build/ linguist-generated
out/ linguist-generated
target/ linguist-generated
